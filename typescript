import React, { useMemo, useState } from "react";

const redFlagRules = [
  {
    label: "Asks for payment or money",
    keywords: ["pay", "payment", "fee", "transfer", "send money", "bank transfer", "deposit", "release fee", "crypto", "bitcoin", "gift card"],
    weight: 3,
  },
  {
    label: "Asks for a code or login details",
    keywords: ["code", "verification", "otp", "password", "login", "pin", "2fa", "one time", "security code"],
    weight: 4,
  },
  {
    label: "Creates urgency or pressure",
    keywords: ["urgent", "immediately", "now", "today", "limited time", "act fast", "final notice", "within 24 hours", "avoid suspension"],
    weight: 2,
  },
  {
    label: "Contains a suspicious link",
    keywords: ["http://", "https://", "bit.ly", "tinyurl", ".xyz", ".top", ".click", ".shop", ".info"],
    weight: 2,
  },
  {
    label: "Threatens account closure, fines, or consequences",
    keywords: ["suspended", "blocked", "closed", "fine", "penalty", "legal action", "arrest", "account locked"],
    weight: 3,
  },
  {
    label: "Too good to be true",
    keywords: ["winner", "prize", "congratulations", "free money", "guaranteed profit", "double your money", "investment opportunity"],
    weight: 3,
  },
  {
    label: "Pushes the conversation to another app",
    keywords: ["whatsapp", "telegram", "signal", "move to", "message me on"],
    weight: 2,
  },
  {
    label: "Delivery or parcel scam pattern",
    keywords: ["parcel", "delivery", "postage", "customs", "package", "auspost", "fedex", "dhl"],
    weight: 2,
  },
  {
    label: "Marketplace scam pattern",
    keywords: ["courier", "pickup agent", "buyer protection", "release payment", "shipping fee", "marketplace"],
    weight: 2,
  },
];

function analyseMessage(message) {
  const text = message.toLowerCase();
  const matched = redFlagRules.filter((rule) =>
    rule.keywords.some((keyword) => text.includes(keyword.toLowerCase()))
  );
  const score = matched.reduce((sum, rule) => sum + rule.weight, 0);

  let risk = "Low";
  let headline = "No major scam signs found, but still verify carefully.";
  let badgeClasses = "bg-emerald-100 text-emerald-800 border-emerald-200";

  if (score >= 10) {
    risk = "Very High";
    headline = "This looks very risky. Do not continue until you verify it safely.";
    badgeClasses = "bg-red-100 text-red-800 border-red-200";
  } else if (score >= 6) {
    risk = "High";
    headline = "This has strong scam warning signs.";
    badgeClasses = "bg-orange-100 text-orange-800 border-orange-200";
  } else if (score >= 3) {
    risk = "Medium";
    headline = "This has some suspicious signs. Be careful before acting.";
    badgeClasses = "bg-yellow-100 text-yellow-800 border-yellow-200";
  }

  const safeSteps = [
    "Do not click suspicious links or download unknown files.",
    "Do not send passwords, verification codes, card details, bank details, or ID documents.",
    "Verify through the official website, official app, or a phone number you already know is real.",
  ];

  if (text.includes("money") || text.includes("pay") || text.includes("bank") || text.includes("card") || text.includes("transfer")) {
    safeSteps.push("If you already sent money or shared banking details, contact your bank immediately.");
  }

  return { score, matched, risk, headline, badgeClasses, safeSteps };
}

export default function CheckBeforeApp() {
  const [message, setMessage] = useState("");
  const [checked, setChecked] = useState(false);

  const result = useMemo(() => analyseMessage(message), [message]);
  const canCheck = message.trim().length >= 10;

  function handleCheck() {
    if (!canCheck) return;
    setChecked(true);
  }

  function handleReset() {
    setMessage("");
    setChecked(false);
  }

  return (
    <div className="min-h-screen bg-slate-50 text-slate-950">
      <main className="mx-auto flex min-h-screen max-w-4xl flex-col px-5 py-8 sm:px-8">
        <section className="mb-8 rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
          <div className="mb-5 inline-flex rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700">
            CheckBefore v1
          </div>
          <h1 className="text-3xl font-bold tracking-tight sm:text-5xl">
            Before you click, pay, reply, or trust it — check first.
          </h1>
          <p className="mt-4 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">
            Paste a suspicious message, link, job offer, marketplace message, or weird DM. This first version looks for common scam warning signs and gives safer next steps.
          </p>
        </section>

        <section className="grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
          <div className="rounded-3xl bg-white p-5 shadow-sm ring-1 ring-slate-200 sm:p-6">
            <label className="text-sm font-semibold text-slate-800" htmlFor="message">
              Suspicious message
            </label>
            <textarea
              id="message"
              value={message}
              onChange={(event) => {
                setMessage(event.target.value);
                setChecked(false);
              }}
              placeholder="Example: Your parcel could not be delivered. Pay a small redelivery fee now using this link..."
              className="mt-3 min-h-56 w-full resize-none rounded-2xl border border-slate-300 bg-white p-4 text-base outline-none transition focus:border-slate-500 focus:ring-4 focus:ring-slate-100"
            />
            <p className="mt-3 text-sm text-slate-500">
              Do not paste passwords, bank details, card numbers, private codes, addresses, or ID numbers.
            </p>
            <div className="mt-5 flex flex-col gap-3 sm:flex-row">
              <button
                onClick={handleCheck}
                disabled={!canCheck}
                className="rounded-2xl bg-slate-950 px-5 py-3 font-semibold text-white shadow-sm transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:bg-slate-300"
              >
                Check risk
              </button>
              <button
                onClick={handleReset}
                className="rounded-2xl border border-slate-300 bg-white px-5 py-3 font-semibold text-slate-700 transition hover:bg-slate-50"
              >
                Clear
              </button>
            </div>
          </div>

          <div className="rounded-3xl bg-white p-5 shadow-sm ring-1 ring-slate-200 sm:p-6">
            <h2 className="text-xl font-bold">Result</h2>
            {!checked ? (
              <div className="mt-5 rounded-2xl bg-slate-50 p-5 text-slate-600">
                Paste a message, then press <span className="font-semibold text-slate-900">Check risk</span>.
              </div>
            ) : (
              <div className="mt-5 space-y-5">
                <div className={`inline-flex rounded-full border px-4 py-2 text-sm font-bold ${result.badgeClasses}`}>
                  Risk level: {result.risk}
                </div>

                <p className="text-lg font-semibold leading-7 text-slate-900">{result.headline}</p>

                <div>
                  <h3 className="font-bold">Red flags found</h3>
                  {result.matched.length > 0 ? (
                    <ul className="mt-2 space-y-2 text-sm text-slate-700">
                      {result.matched.map((rule) => (
                        <li key={rule.label} className="rounded-xl bg-slate-50 p-3">
                          {rule.label}
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <p className="mt-2 rounded-xl bg-slate-50 p-3 text-sm text-slate-600">
                      No obvious red flags were detected by this basic checker. Still verify through official sources.
                    </p>
                  )}
                </div>

                <div>
                  <h3 className="font-bold">Safer next steps</h3>
                  <ul className="mt-2 space-y-2 text-sm text-slate-700">
                    {result.safeSteps.map((step) => (
                      <li key={step} className="rounded-xl bg-slate-50 p-3">
                        {step}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            )}
          </div>
        </section>

        <section className="mt-5 rounded-3xl bg-white p-5 text-sm leading-6 text-slate-600 shadow-sm ring-1 ring-slate-200 sm:p-6">
          <strong className="text-slate-900">Important:</strong> This is a beginner MVP and gives general scam-risk information only. It cannot guarantee something is safe or unsafe. When in doubt, verify through official channels.
        </section>
      </main>
    </div>
  );
}
